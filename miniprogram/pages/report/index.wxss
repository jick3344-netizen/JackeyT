.report-date { margin-top: 14rpx; color: #747268; font-size: 23rpx; }
.score-card { margin: 36rpx 0; padding: 38rpx 32rpx; color: #fffdf8; background: #35352f; }
.score-number { color: #fffdf8; font-size: 96rpx; font-weight: 600; line-height: 1; }
.score-total { color: #d7d1c4; font-size: 30rpx; }
.score-level { margin-top: 12rpx; color: #d7d1c4; font-size: 24rpx; }
.section { margin-top: 48rpx; }
.section-kicker { margin-bottom: 15rpx; color: #8b332a; font-size: 20rpx; font-weight: 700; letter-spacing: 3rpx; }
.section-title { margin-bottom: 16rpx; font-size: 40rpx; font-weight: 600; }
.summary-copy { font-size: 32rpx; line-height: 1.85; }
.dimension { margin-bottom: 14rpx; }
.dimension > view:first-child { display: flex; justify-content: space-between; font-size: 31rpx; font-weight: 600; }
.dimension-status { margin: 8rpx 0; color: #8b332a; font-size: 22rpx; }
.issue, .action { margin-bottom: 14rpx; }
.issue-title { margin: 14rpx 0 7rpx; font-size: 32rpx; font-weight: 600; }
.example { margin-top: 14rpx; color: #68705a; font-size: 24rpx; }
.suggestion { margin-bottom: 14rpx; border-left: 5rpx solid #8b332a; }
.suggestion text { display: block; margin-bottom: 10rpx; color: #8b332a; font-size: 21rpx; }
.suggestion view { font-size: 31rpx; line-height: 1.7; }
.report-footer { margin-top: 56rpx; padding: 34rpx 0; border-top: 1rpx solid #262621; }
.report-footer view { font-size: 38rpx; font-weight: 600; }
.report-footer text { display: block; margin: 10rpx 0 24rpx; color: #747268; font-size: 25rpx; }
